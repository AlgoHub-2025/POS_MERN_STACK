# API Configuration
VITE_API_BASE_URL=http://localhost:3001/api

# WebSocket Configuration
VITE_SOCKET_URL=http://localhost:3001

# Application Configuration
VITE_APP_NAME=AlgoHub POS
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Multi-tenant Point of Sale and Inventory Management System

# Feature Flags
VITE_ENABLE_PWA=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true

# External Services
VITE_SENTRY_DSN=
VITE_GOOGLE_ANALYTICS_ID=

# Map Configuration (for location-based features)
VITE_GOOGLE_MAPS_API_KEY=

# Payment Gateway Configuration
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_PAYPAL_CLIENT_ID=

# File Upload Configuration
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# Development Configuration
VITE_DEV_TOOLS=true
VITE_LOG_LEVEL=debug
